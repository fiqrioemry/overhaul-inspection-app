// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init


generator client {
  provider = "prisma-client-js"
  output = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoleEnum {
  USER
  ADMIN
}

enum StatusEnum {
  ACTIVE
  INACTIVE
  BANNED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  username     String   @unique
  avatar       String?
  bio          String?
  status StatusEnum @default(ACTIVE)
  role         RoleEnum @default(USER)
  verifiedAt  DateTime? @map("verified_at")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  sessions     Session[]
  posts        Post[]
  comments     Comment[]

  verifications UserVerification[]
  followers    Following[] @relation("UserFollowers")
  following    Following[] @relation("UserFollowing")

  activities   UserActivityLog[]

  @@map("users")
}

model Following {
  id          String   @id @default(cuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower    User @relation("UserFollowing", fields: [followerId], references: [id])
  following   User @relation("UserFollowers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])

  @@map("followings")
}

enum VerificationType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model UserVerification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  usedAt   DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  type     VerificationType   @map("type")

  user      User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_verifications")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at") 

  user      User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("sessions")
}

model UserActivityLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user      User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_activity_logs")
}

model Post {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user       User          @relation(fields: [userId], references: [id])
  comments   Comment[]
  galleries  PostGallery[]

  @@index([userId])
  @@map("posts")
}



model fileStorage {
  id        String   @id @default(cuid())
  targetId  String?  @map("target_id")
  url       String
  module    String
  size     Int
  meta     Json?
  path     String
  isUsed   Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("file_storage")
}

model PostGallery {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  url       String
  createdAt DateTime @default(now()) @map("created_at")

  post      Post @relation(fields: [postId], references: [id])

  @@index([postId])
  @@map("post_galleries")
}

model Comment {
  id        String   @id @default(cuid())
  parentId  String?  @map("parent_id")
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  parent    Comment? @relation("CommentChildren", fields: [parentId], references: [id])
  children  Comment[] @relation("CommentChildren")

  @@index([postId])
  @@index([userId])
  @@index([parentId])

  @@map("comments")
}