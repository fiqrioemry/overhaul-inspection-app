 
generator client {
  provider = "prisma-client-js"
  output = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoleEnum {
  USER
  ADMIN
  INSPECTOR
}

enum StatusEnum {
  ACTIVE
  INACTIVE
  BANNED
}


model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?   @map("password_hash")
  name         String
  avatar       String?
  status StatusEnum @default(ACTIVE)
  role         RoleEnum @default(USER)
  verifiedAt  DateTime? @map("verified_at")
  lastLogin    DateTime? @map("last_login")
  lastChangePasswordAt DateTime? @map("last_change_password_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  twoFactorEnabled    Boolean  @default(false) @map("two_factor_enabled")
  twoFactorSecret     String?  @map("two_factor_secret")
  twoFactorBackupCodes String[] @map("two_factor_backup_codes")

  sessions        Session[]
  notifications   Notification[]
  notificationSettings NotificationSetting[]
  verifications UserVerification[]

  activities   UserActivityLog[]
  oauthAccounts    OAuthAccount[]

  @@map("users")
}

 
 

enum VerificationType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model UserVerification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  usedAt   DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  type     VerificationType   @map("type")

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_verifications")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at") 

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model UserActivityLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_activity_logs")
}

 
enum OAuthProvider {
  GOOGLE
  GITHUB

}

model OAuthAccount {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  provider          OAuthProvider
  providerAccountId String        @map("provider_account_id")
  accessToken       String?       @map("access_token")
  refreshToken      String?       @map("refresh_token")
  expiresAt         DateTime?     @map("expires_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}
 
 
model FileStorage {
  id        String   @id @default(cuid())
  targetId  String?  @map("target_id")
  url       String
  module    String
  size     Int
  meta     Json?
  path     String
  isUsed   Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")

  @@map("file_storages")
}

 
enum NotificationType {
  INSPECTION_ASSIGNED
  INSPECTION_REMINDER
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationStatus {
  ENABLED
  DISABLED
}
model NotificationSetting {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus @default(ENABLED)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
  @@index([userId])
  @@map("notification_settings")
}

model Notification {
  id String @id @default(cuid())
  userId String @map("user_id")
  title String
  description String?
  type NotificationType
  metadata  Json?  // cover title, description, targetId (postId, commentId, userId, messageId), etc.
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@map("notifications")
}

 