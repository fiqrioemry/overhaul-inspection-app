// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init


generator client {
  provider = "prisma-client-js"
  output = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoleEnum {
  USER
  ADMIN
}

enum StatusEnum {
  ACTIVE
  INACTIVE
  BANNED
}
enum GenderEnum {
  MALE
  FEMALE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?   @map("password_hash")
  name         String
  username     String   @unique
  avatar       String?
  bio          String?
  status StatusEnum @default(ACTIVE)
  gender GenderEnum?  @map("gender")
  role         RoleEnum @default(USER)
  isPublic     Boolean  @default(true) @map("is_public")
  verifiedAt  DateTime? @map("verified_at")
  lastLogin    DateTime? @map("last_login")
  lastChangePasswordAt DateTime? @map("last_change_password_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  sessions     Session[]
  posts        Post[]
  postReports  PostReport[]
  notifications Notification[]
  notificationSettings NotificationSetting[]
  comments     Comment[]
  likes        Like[]
  chatParticipants ChatParticipant[]
  bookmarks     Bookmark[]
  createdChats Chat[] @relation("ChatCreator")

  verifications UserVerification[]
  followers    Following[] @relation("UserFollowers")
  following    Following[] @relation("UserFollowing")

  activities   UserActivityLog[]
  sentMessages Message[]
 oauthAccounts OAuthAccount[] 
  @@map("users")
}

enum FollowStatus {
  NONE      
  PENDING    
  ACCEPTED   
}

model Following {
  id          String       @id @default(cuid())
  followerId  String       @map("follower_id")
  followingId String       @map("following_id")
  status      FollowStatus @default(ACCEPTED) @map("status")  // public = langsung ACCEPTED
  acceptedAt  DateTime?    @map("accepted_at")  // null jika masih PENDING
  createdAt   DateTime     @default(now()) @map("created_at")

  follower    User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([followingId, status]) // ← penting untuk query "pending requests"
  @@map("followings")
}

enum VerificationType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model UserVerification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  usedAt   DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  type     VerificationType   @map("type")

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_verifications")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at") 

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model UserActivityLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_activity_logs")
}

model Post {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title    String 
  content   String
  isArchived Boolean  @default(false) @map("is_archived")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  postReports PostReport[]
  comments   Comment[]    
  bookmarks  Bookmark[]
  galleries  PostGallery[]
  likes      Like[]

  @@index([userId])
  @@map("posts")
}

 

enum OAuthProvider {
  GOOGLE
  GITHUB

}

model OAuthAccount {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  provider          OAuthProvider
  providerAccountId String        @map("provider_account_id")
  accessToken       String?       @map("access_token")
  refreshToken      String?       @map("refresh_token")
  expiresAt         DateTime?     @map("expires_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}
model Bookmark {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  postId    String   @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])

  @@map("bookmarks")
}


 
model FileStorage {
  id        String   @id @default(cuid())
  targetId  String?  @map("target_id")
  url       String
  module    String
  size     Int
  meta     Json?
  path     String
  isUsed   Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")

  @@map("file_storages")
}

model PostGallery {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  url       String
  order    Int
  createdAt DateTime @default(now()) @map("created_at")

  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_galleries")
}

model Like {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  postId    String?  @map("post_id")
  commentId String?  @map("comment_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post? @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([userId])
  @@index([postId])
  @@index([commentId])

  @@map("likes")
}




model Comment {
  id        String   @id @default(cuid())
  parentId  String?  @map("parent_id")
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes      Like[]

  parent    Comment? @relation("CommentChildren", fields: [parentId], references: [id])
  children  Comment[] @relation("CommentChildren")

  @@index([postId])
  @@index([userId])
  @@index([parentId])

  @@map("comments")
}

enum ChatType {
  PRIVATE
  GROUP
}
model Chat {
  id            String   @id @default(cuid())
  type          ChatType @default(PRIVATE)
  name          String?
  avatar        String?
  description   String?
  createdById   String?  @map("created_by_id")

  lastMessageId String?  @unique @map("last_message_id")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at") 

  createdBy     User? @relation("ChatCreator", fields: [createdById], references: [id])

  participants  ChatParticipant[]  
  messages      Message[]

  lastMessage   Message? @relation("LastMessage", fields: [lastMessageId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([updatedAt])
  @@map("chats")
}


enum ParticipantRole {
  MEMBER
  ADMIN
}
model ChatParticipant {
  id        String   @id @default(cuid())
  chatId    String   @map("chat_id")
  userId    String   @map("user_id")
  role      ParticipantRole @default(MEMBER)
  joinedAt  DateTime @default(now()) @map("joined_at")

  chat      Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([chatId])
  @@index([userId])

  @@map("chat_participants")
}


enum MessageType {
  text
  image
  file
  audio
  video
}
enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  REQUEST 
  MENTION
  MESSAGE
}

enum NotificationChannel {
  IN_APP
}

enum NotificationStatus {
  ENABLED
  DISABLED
}
model NotificationSetting {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus @default(ENABLED)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
  @@index([userId])
  @@map("notification_settings")
}

model Notification {
  id String @id @default(cuid())
  userId String @map("user_id")
  title String
  description String?
  type NotificationType
  metadata  Json?  // cover title, description, targetId (postId, commentId, userId, messageId), etc.
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@map("notifications")
}

model Message {
  id        String   @id @default(cuid())
  chatId    String   @map("chat_id")
  senderId  String   @map("sender_id")
  type      MessageType @default(text)
  text      String
  mediaUrl String?  @map("media_url")
  readBy    String[] @map("read_by")
  createdAt DateTime @default(now()) @map("created_at")

  chat      Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User @relation(fields: [senderId], references: [id], onDelete: Cascade)
  lastMessageInChat Chat? @relation("LastMessage")

  @@index([chatId])
  @@index([senderId])
  @@map("messages")
}

enum PostReportReason {
  SPAM
  HARASSMENT
  NUDITY
  VIOLENCE
  MISSINFORMATION
  OTHER
}

model PostReport {
  id          String           @id @default(cuid())
  postId      String
  userId      String
  reason      PostReportReason
  description String?          // required only when reason = OTHER
  createdAt   DateTime         @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])  
  @@index([postId, reason])  
  @@map("post_reports")
}