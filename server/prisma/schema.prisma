generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

 
enum RoleEnum {
  USER
  INSPECTOR
  ADMIN
  SUPER_ADMIN
}

enum StatusEnum {
  ACTIVE
  INACTIVE
  BANNED
}

enum VerificationType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum OAuthProvider {
  GOOGLE
  GITHUB
}

enum NotificationType {
  INSPECTION_ASSIGNED
  INSPECTION_REMINDER
  INSPECTION_REVIEW_REQUESTED
  INSPECTION_REVIEWED
  TANK_CREATED
  PROCESS_STATUS_UPDATED
  FINDING_CREATED
  FINDING_STATUS_UPDATED
  DAILY_REPORT_CREATED
  TEST_RESULT_UPDATED
  RADIOGRAPHY_RESULT_UPDATED
  FILE_UPLOADED
  USER_CREATED
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationStatus {
  ENABLED
  DISABLED
}

enum CompanyType {
  OWNER
  INSPECTOR_COMPANY
  CONTRACTOR
}

// ─── Master Data Status / Document ───────────────────────────────────────────

enum MasterDataStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum DocumentType {
  STANDARD
  PROCEDURE
  SPECIFICATION
  WPS
  ITP
  PROJECT_PROCEDURE
}

enum AcceptanceType {
  PASS_FAIL
  NUMERIC_MIN
  NUMERIC_MAX
  NUMERIC_RANGE
  TEXT
  DEPENDENCY
}

enum CriteriaSeverity {
  CRITICAL
  MAJOR
  MINOR
  OBSERVATION
}

// ─── Domain Enums ────────────────────────────────────────────────────────────

enum ProcessType {
  WORK
  INSPECTION
  TEST
  NDT
  COATING
  COMMISSIONING
  MATERIAL_INSPECTION
}

enum ProcessResultEnum {
  PASSED
  FAILED
  PENDING
  NOT_APPLICABLE
}

enum ProcessStatusEnum {
  LOCKED
  NOT_STARTED
  WAITING_REVIEW
  REVIEWED
  IN_PROGRESS
  COMPLETED
  // REJECTED
  // NOT_APPLICABLE
}

enum ChecklistStatusEnum {
  NOT_CHECKED
  PASSED
  FAILED
  NOT_APPLICABLE
}

enum FindingStatusEnum {
  OPEN
  IN_REPAIR
  REPAIRED
  VERIFIED
  CLOSED
  REJECTED
}

enum SeverityEnum {
  LOW
  MINOR
  MAJOR
  CRITICAL
}

enum InspectionRequestStatusEnum {
  DRAFT
  SUBMITTED
  REVIEWED
  RETURNED
  CANCELLED
}

enum DailyActivityTypeEnum {
  MONITORING
  INSPECTION
  FINDING
  REPAIR
  TEST_ACTIVITY
  INFORMATION
}

enum RadiographyJointResultEnum {
  PENDING
  ACCEPTED
  REPAIR
  RESHOOT
  REJECTED
}

// ─── Auth Models ─────────────────────────────────────────────────────────────

model User {
  id                   String     @id @default(cuid())
  email                String     @unique
  passwordHash         String?    @map("password_hash")
  name                 String
  avatarFileStorageId  String?    @unique @map("avatar_file_storage_id")
  status               StatusEnum @default(ACTIVE)
  role                 RoleEnum   @default(USER)
  verifiedAt           DateTime?  @map("verified_at")
  lastLogin            DateTime?  @map("last_login")
  lastChangePasswordAt DateTime?  @map("last_change_password_at")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  deletedAt            DateTime?  @map("deleted_at")

  twoFactorEnabled     Boolean  @default(false) @map("two_factor_enabled")
  twoFactorSecret      String?  @map("two_factor_secret")
  twoFactorBackupCodes String[] @map("two_factor_backup_codes")

  sessions             Session[]
  notifications        Notification[]
  notificationSettings NotificationSetting[]
  verifications        UserVerification[]
  activities           UserActivityLog[]
  oauthAccounts        OAuthAccount[]

  createdTanks         Tank[]              @relation("TankCreatedBy")
  reviewedRequests     InspectionRequest[] @relation("InspectionRequestReviewedBy")
  requestedReviews     InspectionRequest[] @relation("InspectionRequestRequestedBy")
  createdFindings      Finding[]           @relation("FindingCreatedBy")
  closedFindings       Finding[]           @relation("FindingClosedBy")
  checkedChecklists    ChecklistResult[]   @relation("ChecklistCheckedBy")
  createdTestRecords   TestRecord[]        @relation("TestRecordCreatedBy")
  createdRadiography   RadiographyTest[]   @relation("RadiographyCreatedBy")
  dailyReports         DailyReport[]       @relation("DailyReportInspector")
  avatarFile           FileStorage? @relation("UserAvatar", fields: [avatarFileStorageId], references: [id], onDelete: SetNull)


  @@index([email])
  @@index([role])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model UserVerification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  token     String           @unique
  usedAt    DateTime?        @map("used_at")
  createdAt DateTime         @default(now()) @map("created_at")
  expiresAt DateTime         @map("expires_at")
  type      VerificationType @map("type")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_verifications")
}

model UserActivityLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_activity_logs")
}

model OAuthAccount {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  provider          OAuthProvider
  providerAccountId String        @map("provider_account_id")
  accessToken       String?       @map("access_token")
  refreshToken      String?       @map("refresh_token")
  expiresAt         DateTime?     @map("expires_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

// ─── File Storage ─────────────────────────────────────────────────────────────

model FileStorage {
  id        String   @id @default(cuid())
  targetId  String?  @map("target_id")
  url       String
  module    String
  mimeType  String?  @map("mime_type")
  size      Int
  meta      Json?
  path      String
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")

  avatarOfUser User? @relation("UserAvatar")
  @@index([isUsed, createdAt])
  @@map("file_storages")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model NotificationSetting {
  id        String              @id @default(cuid())
  userId    String              @map("user_id")
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(ENABLED)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
  @@index([userId])
  @@map("notification_settings")
}

model Notification {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  title       String
  description String?
  type        NotificationType
  metadata    Json?
  readAt      DateTime?        @map("read_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  deletedAt   DateTime?        @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@index([userId, readAt])
  @@map("notifications")
}

// ─── Company ──────────────────────────────────────────────────────────────────

model Company {
  id        String      @id @default(cuid())
  name      String
  type      CompanyType
  address   String?
  phone     String?
  email     String?
  logoUrl   String?     @map("logo_url")
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  deletedAt DateTime?   @map("deleted_at")

  contractorTanks Tank[] @relation("TankContractor")
  inspectionTanks Tank[] @relation("TankInspectionCompany")

  @@index([type])
  @@index([isActive])
  @@index([deletedAt])
  @@map("companies")
}

// ─── Master Data ──────────────────────────────────────────────────────────────

model ReferenceDocument {
  id           String           @id @default(cuid())
  code         String           @unique
  title        String
  documentType DocumentType     @map("document_type")
  revision     String?
  issuer       String?
  fileUrl      String?          @map("file_url")
  status       MasterDataStatus @default(DRAFT)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  deletedAt    DateTime?        @map("deleted_at")

  criteriaRefs CriteriaReference[]

  @@index([code])
  @@index([documentType])
  @@index([status])
  @@index([deletedAt])
  @@map("reference_documents")
}

model AcceptanceCriteria {
  id             String           @id @default(cuid())
  code           String           @unique
  name           String
  description    String?
  acceptanceType AcceptanceType   @map("acceptance_type")
  operator       String?
  minValue       Float?           @map("min_value")
  maxValue       Float?           @map("max_value")
  unit           String?
  acceptanceText String?          @map("acceptance_text")
  method         String?
  tools          String?
  isRequired     Boolean          @default(true) @map("is_required")
  severity       CriteriaSeverity @default(MAJOR)
  status         MasterDataStatus @default(DRAFT)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  criteriaRefs     CriteriaReference[]
  processCriteria  ProcessCriteriaTemplate[]
  checklistResults ChecklistResult[]
  findings         Finding[]

  @@index([code])
  @@index([acceptanceType])
  @@index([status])
  @@index([deletedAt])
  @@map("acceptance_criteria")
}

model CriteriaReference {
  id                  String             @id @default(cuid())
  criteriaId          String             @map("criteria_id")
  referenceDocumentId String             @map("reference_document_id")
  clause              String?
  page                String?
  notes               String?
  createdAt           DateTime           @default(now()) @map("created_at")

  criteria          AcceptanceCriteria @relation(fields: [criteriaId], references: [id], onDelete: Cascade)
  referenceDocument ReferenceDocument  @relation(fields: [referenceDocumentId], references: [id], onDelete: Restrict)

  @@unique([criteriaId, referenceDocumentId])
  @@index([criteriaId])
  @@index([referenceDocumentId])
  @@map("criteria_references")
}

model ProcessTemplate {
  id                String      @id @default(cuid())
  code              String      @unique
  name              String
  type              ProcessType
  sequenceOrder     Int         @map("sequence_order")
  isOptional        Boolean     @default(false) @map("is_optional")
  applicabilityRule String?     @map("applicability_rule")
  isActive          Boolean     @default(true) @map("is_active")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  deletedAt         DateTime?   @map("deleted_at")

  processCriteria ProcessCriteriaTemplate[]
  dependants      ProcessDependency[]        @relation("DependantProcess")
  dependencies    ProcessDependency[]        @relation("RequiredProcess")
  tankProcesses   TankProcess[]

  @@index([type])
  @@index([sequenceOrder])
  @@index([isActive])
  @@index([deletedAt])
  @@map("process_templates")
}

model ProcessCriteriaTemplate {
  id                String    @id @default(cuid())
  processTemplateId String    @map("process_template_id")
  criteriaId        String    @map("criteria_id")
  sequenceOrder     Int       @default(0) @map("sequence_order")
  isRequired        Boolean   @default(true) @map("is_required")
  applicabilityRule String?   @map("applicability_rule")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  processTemplate ProcessTemplate    @relation(fields: [processTemplateId], references: [id], onDelete: Cascade)
  criteria        AcceptanceCriteria @relation(fields: [criteriaId], references: [id], onDelete: Restrict)

  @@unique([processTemplateId, criteriaId])
  @@index([processTemplateId])
  @@index([criteriaId])
  @@map("process_criteria_templates")
}

model ProcessDependency {
  id                        String            @id @default(cuid())
  processTemplateId         String            @map("process_template_id")
  requiredProcessTemplateId String            @map("required_process_template_id")
  requiredResult            ProcessResultEnum @default(PASSED) @map("required_result")
  isRequired                Boolean           @default(true) @map("is_required")
  applicabilityRule         String?           @map("applicability_rule")
  createdAt                 DateTime          @default(now()) @map("created_at")
  updatedAt                 DateTime          @updatedAt @map("updated_at")

  processTemplate         ProcessTemplate @relation("DependantProcess", fields: [processTemplateId], references: [id], onDelete: Cascade)
  requiredProcessTemplate ProcessTemplate @relation("RequiredProcess", fields: [requiredProcessTemplateId], references: [id], onDelete: Restrict)

  @@unique([processTemplateId, requiredProcessTemplateId])
  @@index([processTemplateId])
  @@index([requiredProcessTemplateId])
  @@map("process_dependencies")
}

// ─── Tank Domain ──────────────────────────────────────────────────────────────

model Tank {
  id                  String     @id @default(cuid())
  tankNo              String     @unique @map("tank_no")
  tankName            String?    @map("tank_name")
  diameterMm          Float?     @map("diameter_mm")
  heightMm            Float?     @map("height_mm")
  shellCourseCount    Int?       @map("shell_course_count")
  bottomPlateDimension String?   @map("bottom_plate_dimension")
  hasSteamCoil        Boolean    @default(false) @map("has_steam_coil")
  contractorCompanyId String?    @map("contractor_company_id")
  inspectionCompanyId String?    @map("inspection_company_id")
  startDate           DateTime?  @map("start_date") @db.Date
  estimatedFinishDate DateTime?  @map("estimated_finish_date") @db.Date
  actualFinishDate    DateTime?  @map("actual_finish_date") @db.Date
  status              StatusEnum @default(ACTIVE)
  createdBy           String?    @map("created_by")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  deletedAt           DateTime?  @map("deleted_at")

  contractorCompany Company?   @relation("TankContractor", fields: [contractorCompanyId], references: [id])
  inspectionCompany Company?   @relation("TankInspectionCompany", fields: [inspectionCompanyId], references: [id])
  createdByUser     User?      @relation("TankCreatedBy", fields: [createdBy], references: [id])

  shellCourses TankShellCourse[]
  processes    TankProcess[]
  findings     Finding[]
  dailyReports DailyReport[]

  @@index([status])
  @@index([deletedAt])
  @@map("tanks")
}

model TankShellCourse {
  id             String   @id @default(cuid())
  tankId         String   @map("tank_id")
  courseNo       Int      @map("course_no")
  thicknessMm    Float?   @map("thickness_mm")
  plateDimension String?  @map("plate_dimension")
  remarks        String?

  tank Tank @relation(fields: [tankId], references: [id], onDelete: Cascade)

  @@unique([tankId, courseNo])
  @@index([tankId])
  @@map("tank_shell_courses")
}

model TankProcess {
  id                String            @id @default(cuid())
  tankId            String            @map("tank_id")
  processTemplateId String            @map("process_template_id")
  name              String
  type              ProcessType
  sequenceOrder     Int               @map("sequence_order")
  status            ProcessStatusEnum @default(LOCKED)
  result            ProcessResultEnum @default(PENDING)
  plannedStartDate  DateTime?         @map("planned_start_date") @db.Date
  actualStartDate   DateTime?         @map("actual_start_date") @db.Date
  actualFinishDate  DateTime?         @map("actual_finish_date") @db.Date
  remarks           String?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  tank            Tank            @relation(fields: [tankId], references: [id], onDelete: Cascade)
  processTemplate ProcessTemplate @relation(fields: [processTemplateId], references: [id], onDelete: Restrict)

  checklistResults   ChecklistResult[]
  findings           Finding[]
  inspectionRequests InspectionRequest[]
  testRecords        TestRecord[]
  radiographyTests   RadiographyTest[]
  dailyReports       DailyReport[]

  @@unique([tankId, processTemplateId])
  @@index([tankId])
  @@index([status])
  @@index([result])
  @@map("tank_processes")
}

model ChecklistResult {
  id            String              @id @default(cuid())
  tankProcessId String              @map("tank_process_id")
  criteriaId    String              @map("criteria_id")
  status        ChecklistStatusEnum @default(NOT_CHECKED)
  actualValue   Float?              @map("actual_value")
  actualText    String?             @map("actual_text")
  remarks       String?
  checkedBy     String?             @map("checked_by")
  checkedAt     DateTime?           @map("checked_at")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  tankProcess   TankProcess        @relation(fields: [tankProcessId], references: [id], onDelete: Cascade)
  criteria      AcceptanceCriteria @relation(fields: [criteriaId], references: [id], onDelete: Restrict)
  checkedByUser User?              @relation("ChecklistCheckedBy", fields: [checkedBy], references: [id])

  @@unique([tankProcessId, criteriaId])
  @@index([tankProcessId])
  @@index([criteriaId])
  @@index([status])
  @@map("checklist_results")
}

model Finding {
  id             String            @id @default(cuid())
  tankId         String            @map("tank_id")
  tankProcessId  String            @map("tank_process_id")
  criteriaId     String?           @map("criteria_id")
  findingNo      String            @unique @map("finding_no")
  title          String
  description    String?
  locationDetail String?           @map("location_detail")
  status         FindingStatusEnum @default(OPEN)
  severity       SeverityEnum      @default(MAJOR)
  isBlocking     Boolean           @default(true) @map("is_blocking")
  createdBy      String?           @map("created_by")
  closedBy       String?           @map("closed_by")
  closedAt       DateTime?         @map("closed_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  deletedAt      DateTime?         @map("deleted_at")

  tank          Tank                @relation(fields: [tankId], references: [id], onDelete: Cascade)
  tankProcess   TankProcess         @relation(fields: [tankProcessId], references: [id], onDelete: Cascade)
  criteria      AcceptanceCriteria? @relation(fields: [criteriaId], references: [id], onDelete: SetNull)
  createdByUser User?               @relation("FindingCreatedBy", fields: [createdBy], references: [id])
  closedByUser  User?               @relation("FindingClosedBy", fields: [closedBy], references: [id])

  @@index([tankId])
  @@index([tankProcessId])
  @@index([status])
  @@index([deletedAt])
  @@map("findings")
}

model InspectionRequest {
  id            String                      @id @default(cuid())
  tankProcessId String                      @map("tank_process_id")
  requestNo     String                      @unique @map("request_no")
  requestedBy   String?                     @map("requested_by")
  reviewedBy    String?                     @map("reviewed_by")
  status        InspectionRequestStatusEnum @default(DRAFT)
  notes         String?
  reviewNotes   String?                     @map("review_notes")
  requestedAt   DateTime?                   @map("requested_at")
  reviewedAt    DateTime?                   @map("reviewed_at")
  createdAt     DateTime                    @default(now()) @map("created_at")
  updatedAt     DateTime                    @updatedAt @map("updated_at")

  tankProcess     TankProcess @relation(fields: [tankProcessId], references: [id], onDelete: Cascade)
  requestedByUser User?       @relation("InspectionRequestRequestedBy", fields: [requestedBy], references: [id])
  reviewedByUser  User?       @relation("InspectionRequestReviewedBy", fields: [reviewedBy], references: [id])

  @@index([tankProcessId])
  @@index([status])
  @@map("inspection_requests")
}

model TestRecord {
  id            String            @id @default(cuid())
  tankProcessId String            @map("tank_process_id")
  testDate      DateTime?         @map("test_date") @db.Date
  testPressure  Float?            @map("test_pressure")
  pressureUnit  String?           @map("pressure_unit")
  holdingTime   String?           @map("holding_time")
  testMedium    String?           @map("test_medium")
  leakIndication Boolean?         @map("leak_indication")
  result        ProcessResultEnum @default(PENDING)
  remarks       String?
  createdBy     String?           @map("created_by")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  tankProcess   TankProcess @relation(fields: [tankProcessId], references: [id], onDelete: Cascade)
  createdByUser User?       @relation("TestRecordCreatedBy", fields: [createdBy], references: [id])

  @@index([tankProcessId])
  @@index([result])
  @@map("test_records")
}

model RadiographyTest {
  id            String            @id @default(cuid())
  tankProcessId String            @map("tank_process_id")
  testDate      DateTime?         @map("test_date") @db.Date
  area          String?
  totalJoint    Int               @default(0) @map("total_joint")
  totalShot     Int               @default(0) @map("total_shot")
  totalAccepted Int               @default(0) @map("total_accepted")
  totalRepair   Int               @default(0) @map("total_repair")
  totalReshoot  Int               @default(0) @map("total_reshoot")
  result        ProcessResultEnum @default(PENDING)
  remarks       String?
  createdBy     String?           @map("created_by")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  tankProcess  TankProcess              @relation(fields: [tankProcessId], references: [id], onDelete: Cascade)
  createdByUser User?                   @relation("RadiographyCreatedBy", fields: [createdBy], references: [id])
  jointResults RadiographyJointResult[]

  @@index([tankProcessId])
  @@index([result])
  @@map("radiography_tests")
}

model RadiographyJointResult {
  id                String                    @id @default(cuid())
  radiographyTestId String                    @map("radiography_test_id")
  jointNo           String                    @map("joint_no")
  location          String?
  weldType          String?                   @map("weld_type")
  welderNo          String?                   @map("welder_no")
  filmNo            String?                   @map("film_no")
  result            RadiographyJointResultEnum @default(PENDING)
  defectType        String?                   @map("defect_type")
  repairStatus      String?                   @map("repair_status")
  remarks           String?
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  radiographyTest RadiographyTest @relation(fields: [radiographyTestId], references: [id], onDelete: Cascade)

  @@index([radiographyTestId])
  @@map("radiography_joint_results")
}

model DailyReport {
  id             String                @id @default(cuid())
  tankId         String                @map("tank_id")
  tankProcessId  String?               @map("tank_process_id")
  reportDate     DateTime              @map("report_date") @db.Date
  activityType   DailyActivityTypeEnum @map("activity_type")
  description    String
  inspectorId    String?               @map("inspector_id")
  pertaminaPicId String?               @map("pertamina_pic_id")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  deletedAt      DateTime?             @map("deleted_at")

  tank        Tank         @relation(fields: [tankId], references: [id], onDelete: Cascade)
  tankProcess TankProcess? @relation(fields: [tankProcessId], references: [id], onDelete: SetNull)
  inspector   User?        @relation("DailyReportInspector", fields: [inspectorId], references: [id])

  @@index([tankId])
  @@index([tankProcessId])
  @@index([reportDate])
  @@map("daily_reports")
}
