generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum RoleEnum {
  USER
  INSPECTOR
  ADMIN
  SUPER_ADMIN
}

enum StatusEnum {
  ACTIVE
  INACTIVE
  BANNED
}

enum VerificationType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum OAuthProvider {
  GOOGLE
  GITHUB
}

enum NotificationType {
  INSPECTION_ASSIGNED
  INSPECTION_REMINDER
  INSPECTION_REQUEST_SUBMITTED
  INSPECTION_REQUEST_REVIEWED
  FINDING_CREATED
  FINDING_STATUS_CHANGED
  TEST_COMPLETED
  DAILY_REPORT_CREATED
  TANK_CREATED
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationStatus {
  ENABLED
  DISABLED
}

enum CompanyType {
  OWNER
  INSPECTOR_COMPANY
  CONTRACTOR
}

// ─── Auth Models ─────────────────────────────────────────────────────────────

model User {
  id                   String     @id @default(cuid())
  email                String     @unique
  passwordHash         String?    @map("password_hash")
  name                 String
  avatar               String?
  status               StatusEnum @default(ACTIVE)
  role                 RoleEnum   @default(USER)
  verifiedAt           DateTime?  @map("verified_at")
  lastLogin            DateTime?  @map("last_login")
  lastChangePasswordAt DateTime?  @map("last_change_password_at")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  deletedAt            DateTime?  @map("deleted_at")

  twoFactorEnabled     Boolean  @default(false) @map("two_factor_enabled")
  twoFactorSecret      String?  @map("two_factor_secret")
  twoFactorBackupCodes String[] @map("two_factor_backup_codes")

  sessions             Session[]
  notifications        Notification[]
  notificationSettings NotificationSetting[]
  verifications        UserVerification[]
  activities           UserActivityLog[]
  oauthAccounts        OAuthAccount[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model UserVerification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  token     String           @unique
  usedAt    DateTime?        @map("used_at")
  createdAt DateTime         @default(now()) @map("created_at")
  expiresAt DateTime         @map("expires_at")
  type      VerificationType @map("type")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_verifications")
}

model UserActivityLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_activity_logs")
}

model OAuthAccount {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  provider          OAuthProvider
  providerAccountId String        @map("provider_account_id")
  accessToken       String?       @map("access_token")
  refreshToken      String?       @map("refresh_token")
  expiresAt         DateTime?     @map("expires_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

// ─── File Storage ─────────────────────────────────────────────────────────────

model FileStorage {
  id        String   @id @default(cuid())
  targetId  String?  @map("target_id")
  url       String
  module    String
  mimeType  String?  @map("mime_type")
  size      Int
  meta      Json?
  path      String
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")

  @@index([targetId, module])
  @@index([isUsed, createdAt])
  @@map("file_storages")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model NotificationSetting {
  id        String              @id @default(cuid())
  userId    String              @map("user_id")
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(ENABLED)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
  @@index([userId])
  @@map("notification_settings")
}

model Notification {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  title       String
  description String?
  type        NotificationType
  metadata    Json?
  readAt      DateTime?        @map("read_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  deletedAt   DateTime?        @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@index([userId, readAt])
  @@map("notifications")
}

// ─── Company ──────────────────────────────────────────────────────────────────

model Company {
  id        String      @id @default(cuid())
  name      String
  type      CompanyType
  address   String?
  phone     String?
  email     String?
  logoUrl   String?     @map("logo_url")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  deletedAt DateTime?   @map("deleted_at")

  @@index([type])
  @@index([deletedAt])
  @@map("companies")
}
