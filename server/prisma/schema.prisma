generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoleEnum {
  USER
  INSPECTOR
  ADMIN
  SUPER_ADMIN
}

enum StatusEnum {
  ACTIVE
  INACTIVE
  BANNED
}

enum VerificationType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum OAuthProvider {
  GOOGLE
  GITHUB
}

enum NotificationType {
  INSPECTION_ASSIGNED
  INSPECTION_REMINDER
  INSPECTION_REVIEW_REQUESTED
  INSPECTION_REVIEWED
  TANK_CREATED
  PROCESS_STATUS_UPDATED
  FINDING_CREATED
  FINDING_STATUS_UPDATED
  DAILY_REPORT_CREATED
  TEST_RESULT_UPDATED
  RADIOGRAPHY_RESULT_UPDATED
  FILE_UPLOADED
  USER_CREATED
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationStatus {
  ENABLED
  DISABLED
}

enum CompanyType {
  OWNER
  INSPECTOR_COMPANY
  CONTRACTOR
}

// ─── Master Data Status / Document ───────────────────────────────────────────

enum MasterDataStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum DocumentType {
  STANDARD
  PROCEDURE
  SPECIFICATION
  WPS
  ITP
  PROJECT_PROCEDURE
}

enum AcceptanceType {
  PASS_FAIL
  NUMERIC_MIN
  NUMERIC_MAX
  NUMERIC_RANGE
  TEXT
  DEPENDENCY
}

enum CriteriaSeverity {
  CRITICAL
  MAJOR
  MINOR
  OBSERVATION
}

// ─── Domain Enums ────────────────────────────────────────────────────────────

enum ProcessType {
  WORK
  INSPECTION
  TEST
  NDT
  COATING
  COMMISSIONING
  MATERIAL_INSPECTION
}

enum ProcessResultEnum {
  PASSED
  FAILED
  PENDING
  NOT_APPLICABLE
}

enum ProcessStatusEnum {
  NOT_STARTED
  WAITING_REVIEW
  REVIEWED
  IN_PROGRESS
  COMPLETED
}

enum ChecklistStatusEnum {
  NOT_CHECKED
  PASSED
}

enum ChecklistSourceEnum {
  TEMPLATE
  CUSTOM
}

enum FindingStatusEnum {
  OPEN
  IN_REPAIR
  CLOSE
}

enum SeverityEnum {
  LOW
  MINOR
  MAJOR
  CRITICAL
}

enum InspectionRequestStatusEnum {
  NOT_STARTED
  IN_PROCESS
  REPAIR
  PASSED
}

enum InspectionRequestTypeEnum {
  PENETRANT_TEST
  RADIOGRAPHY_TEST
  OIL_LEAK_TEST
  PNEUMATIC_REINFORCEMENT_TEST
  HYDROTEST_SHELL
  HYDROTEST_PIPE
  PNEUMATIC_BOTTOM_TEST
  PNEUMATIC_ROOF_TEST
  MATERIAL_INSPECTION
  VISUAL_INSPECTION
  COATING_INSPECTION
  OTHER
}

enum InspectionObjectTypeEnum {
  MANHOLE
  COD
  NOZZLE
  SHELL_PLATE
  BOTTOM_PLATE
  ROOF_PLATE
  REINFORCEMENT_PAD
  PIPE
  STEAM_COIL
  WELD_JOINT
  ANNULAR_PLATE
  FLOOR_PLATE
  VALVE
  FLANGE
  FITTING
  MATERIAL
  OTHER
}

enum InspectionRequestAttachmentTypeEnum {
  SUPPORTING_DOCUMENT
  GENERATED_REQUEST_FORM
  SIGNED_REQUEST_FORM
  SKETCH
  OTHER
}

enum TestResultStatusEnum {
  NOT_STARTED
  REPAIR
  PASSED
}

enum DailyActivityTypeEnum {
  MONITORING
  INSPECTION
}

enum TankLocationEnum {
  SUNGAI_GERONG
  PLADJU
}

enum TankServiceEnum {
  AVTUR
  NAPTHA
  PREMIUM
  PERTALITE
  PERTAMAX
  PERTAMAX_TURBO
  SOLAR
  DEXLITE
  PERTAMINA_DEX
  KEROSENE
  CRUDE_OIL
  FUEL_OIL
  LUBRICATING_OIL
  LPG
  CONDENSATE
  SLOP_OIL
  OTHER
}

enum TankAssetStatusEnum {
  OPERATIONAL
  UNDER_OVERHAUL
  OUT_OF_SERVICE
  DECOMMISSIONED
}

enum TankProjectTypeEnum {
  NEW_BUILD
  OVERHAUL
  REPAIR
  ROUTINE_INSPECTION
}

enum TankProjectStatusEnum {
  PLANNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

// ─── Auth Models ─────────────────────────────────────────────────────────────

model User {
  id                   String     @id @default(cuid())
  email                String     @unique
  passwordHash         String?    @map("password_hash")
  name                 String
  avatarFileStorageId  String?    @unique @map("avatar_file_storage_id")
  status               StatusEnum @default(ACTIVE)
  role                 RoleEnum   @default(USER)
  position             String?
  companyId            String?    @map("company_id")
  verifiedAt           DateTime?  @map("verified_at")
  lastLogin            DateTime?  @map("last_login")
  lastChangePasswordAt DateTime?  @map("last_change_password_at")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  deletedAt            DateTime?  @map("deleted_at")

  twoFactorEnabled     Boolean  @default(false) @map("two_factor_enabled")
  twoFactorSecret      String?  @map("two_factor_secret")
  twoFactorBackupCodes String[] @map("two_factor_backup_codes")

  sessions             Session[]
  notifications        Notification[]
  notificationSettings NotificationSetting[]
  verifications        UserVerification[]
  activities           UserActivityLog[]
  oauthAccounts        OAuthAccount[]

  createdTanks        Tank[]              @relation("TankCreatedBy")
  createdTankProjects TankProject[]       @relation("TankProjectCreatedBy")
  requestedReviews    InspectionRequest[] @relation("InspectionRequestRequestedBy")
  receivedRequests    InspectionRequest[] @relation("InspectionRequestReceivedBy")
  preparedRequests    InspectionRequest[] @relation("InspectionRequestPreparedBy")
  approvedRequests    InspectionRequest[] @relation("InspectionRequestApprovedBy")
  createdFindings     Finding[]           @relation("FindingCreatedBy")
  closedFindings      Finding[]           @relation("FindingClosedBy")
  checkedChecklists   ChecklistResult[]   @relation("ChecklistCheckedBy")
  createdTestRecords  TestRecord[]        @relation("TestRecordCreatedBy")
  dailyReports        DailyReport[]       @relation("DailyReportInspector")
  avatarFile          FileStorage?        @relation("UserAvatar", fields: [avatarFileStorageId], references: [id], onDelete: SetNull)
  company             Company?            @relation("CompanyUsers", fields: [companyId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([companyId])
  @@index([deletedAt])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model UserVerification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  token     String           @unique
  usedAt    DateTime?        @map("used_at")
  createdAt DateTime         @default(now()) @map("created_at")
  expiresAt DateTime         @map("expires_at")
  type      VerificationType @map("type")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_verifications")
}

model UserActivityLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_activity_logs")
}

model OAuthAccount {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  provider          OAuthProvider
  providerAccountId String        @map("provider_account_id")
  accessToken       String?       @map("access_token")
  refreshToken      String?       @map("refresh_token")
  expiresAt         DateTime?     @map("expires_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

// ─── File Storage ─────────────────────────────────────────────────────────────

model FileStorage {
  id        String   @id @default(cuid())
  targetId  String?  @map("target_id")
  url       String
  module    String
  mimeType  String?  @map("mime_type")
  size      Int
  meta      Json?
  path      String
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")

  avatarOfUser                 User?                         @relation("UserAvatar")
  logoOfCompany                Company?                      @relation("CompanyLogo")
  dailyReportAttachments       DailyReportAttachment[]
  tankAttachments              TankAttachment[]
  inspectionRequestAttachments InspectionRequestAttachment[]
  testRecordAttachments        TestRecordAttachment[]

  @@index([isUsed, createdAt])
  @@map("file_storages")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model NotificationSetting {
  id        String              @id @default(cuid())
  userId    String              @map("user_id")
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(ENABLED)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
  @@index([userId])
  @@map("notification_settings")
}

model Notification {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  title       String
  description String?
  type        NotificationType
  metadata    Json?
  readAt      DateTime?        @map("read_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  deletedAt   DateTime?        @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@index([userId, readAt])
  @@map("notifications")
}

// ─── Company ──────────────────────────────────────────────────────────────────

model Company {
  id                String      @id @default(cuid())
  name              String
  type              CompanyType
  address           String?
  phone             String?
  email             String?
  logoFileStorageId String?     @unique @map("logo_file_storage_id")
  isActive          Boolean     @default(true) @map("is_active")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  deletedAt         DateTime?   @map("deleted_at")

  logoFile           FileStorage?        @relation("CompanyLogo", fields: [logoFileStorageId], references: [id], onDelete: SetNull)
  contractorProjects TankProject[]       @relation("TankProjectContractor")
  inspectionProjects TankProject[]       @relation("TankProjectInspectionCompany")
  users              User[]              @relation("CompanyUsers")
  executionRequests  InspectionRequest[] @relation("InspectionRequestExecutionCompany")

  @@index([type])
  @@index([isActive])
  @@index([deletedAt])
  @@map("companies")
}

// ─── Master Data ──────────────────────────────────────────────────────────────

model ReferenceDocument {
  id           String           @id @default(cuid())
  code         String           @unique
  title        String
  documentType DocumentType     @map("document_type")
  revision     String?
  issuer       String?
  fileUrl      String?          @map("file_url")
  status       MasterDataStatus @default(DRAFT)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  deletedAt    DateTime?        @map("deleted_at")

  criteriaRefs CriteriaReference[]

  @@index([code])
  @@index([documentType])
  @@index([status])
  @@index([deletedAt])
  @@map("reference_documents")
}

model AcceptanceCriteria {
  id             String           @id @default(cuid())
  code           String           @unique
  name           String
  description    String?
  acceptanceType AcceptanceType   @map("acceptance_type")
  operator       String?
  minValue       Float?           @map("min_value")
  maxValue       Float?           @map("max_value")
  unit           String?
  acceptanceText String?          @map("acceptance_text")
  method         String?
  tools          String?
  isRequired     Boolean          @default(true) @map("is_required")
  severity       CriteriaSeverity @default(MAJOR)
  status         MasterDataStatus @default(DRAFT)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  criteriaRefs     CriteriaReference[]
  processCriteria  ProcessCriteriaTemplate[]
  checklistResults ChecklistResult[]
  findings         Finding[]

  @@index([code])
  @@index([acceptanceType])
  @@index([status])
  @@index([deletedAt])
  @@map("acceptance_criteria")
}

model CriteriaReference {
  id                  String   @id @default(cuid())
  criteriaId          String   @map("criteria_id")
  referenceDocumentId String   @map("reference_document_id")
  clause              String?
  page                String?
  notes               String?
  createdAt           DateTime @default(now()) @map("created_at")

  criteria          AcceptanceCriteria @relation(fields: [criteriaId], references: [id], onDelete: Cascade)
  referenceDocument ReferenceDocument  @relation(fields: [referenceDocumentId], references: [id], onDelete: Restrict)

  @@unique([criteriaId, referenceDocumentId])
  @@index([criteriaId])
  @@index([referenceDocumentId])
  @@map("criteria_references")
}

model ProcessTemplate {
  id                String      @id @default(cuid())
  code              String      @unique
  name              String
  type              ProcessType
  sequenceOrder     Int         @map("sequence_order")
  isOptional        Boolean     @default(false) @map("is_optional")
  applicabilityRule String?     @map("applicability_rule")
  isActive          Boolean     @default(true) @map("is_active")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  deletedAt         DateTime?   @map("deleted_at")

  processCriteria ProcessCriteriaTemplate[]
  dependants      ProcessDependency[]       @relation("DependantProcess")
  dependencies    ProcessDependency[]       @relation("RequiredProcess")
  tankProcesses   TankProcess[]

  @@index([type])
  @@index([sequenceOrder])
  @@index([isActive])
  @@index([deletedAt])
  @@map("process_templates")
}

model ProcessCriteriaTemplate {
  id                String   @id @default(cuid())
  processTemplateId String   @map("process_template_id")
  criteriaId        String   @map("criteria_id")
  sequenceOrder     Int      @default(0) @map("sequence_order")
  isRequired        Boolean  @default(true) @map("is_required")
  applicabilityRule String?  @map("applicability_rule")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  processTemplate ProcessTemplate    @relation(fields: [processTemplateId], references: [id], onDelete: Cascade)
  criteria        AcceptanceCriteria @relation(fields: [criteriaId], references: [id], onDelete: Restrict)

  @@unique([processTemplateId, criteriaId])
  @@index([processTemplateId])
  @@index([criteriaId])
  @@map("process_criteria_templates")
}

model ProcessDependency {
  id                        String            @id @default(cuid())
  processTemplateId         String            @map("process_template_id")
  requiredProcessTemplateId String            @map("required_process_template_id")
  requiredStatus            ProcessStatusEnum @default(COMPLETED) @map("required_status")
  isRequired                Boolean           @default(true) @map("is_required")
  applicabilityRule         String?           @map("applicability_rule")
  createdAt                 DateTime          @default(now()) @map("created_at")
  updatedAt                 DateTime          @updatedAt @map("updated_at")

  processTemplate         ProcessTemplate @relation("DependantProcess", fields: [processTemplateId], references: [id], onDelete: Cascade)
  requiredProcessTemplate ProcessTemplate @relation("RequiredProcess", fields: [requiredProcessTemplateId], references: [id], onDelete: Restrict)

  @@unique([processTemplateId, requiredProcessTemplateId])
  @@index([processTemplateId])
  @@index([requiredProcessTemplateId])
  @@map("process_dependencies")
}

// ─── Tank Domain ──────────────────────────────────────────────────────────────

model Tank {
  id String @id @default(cuid())
  // Uniqueness of tank_no is enforced only among active rows (deleted_at IS NULL) via a
  // partial unique index created in migration 20260702030000_tank_no_partial_unique_active.
  // Prisma cannot express filtered/partial unique indexes in the schema, so it is managed
  // by raw SQL in that migration — do NOT re-add @unique here.
  tankNo               String              @map("tank_no")
  tankName             String?             @map("tank_name")
  diameterMm           Float?              @map("diameter_mm")
  heightMm             Float?              @map("height_mm")
  shellCourseCount     Int?                @map("shell_course_count")
  bottomPlateDimension String?             @map("bottom_plate_dimension")
  hasSteamCoil         Boolean             @default(false) @map("has_steam_coil")
  location             TankLocationEnum?   @map("location")
  capacityM3           Float?              @map("capacity_m3")
  service              TankServiceEnum?    @map("service")
  assetStatus          TankAssetStatusEnum @default(OPERATIONAL) @map("asset_status")
  createdBy            String?             @map("created_by")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  deletedAt            DateTime?           @map("deleted_at")

  aiExtractedAt    DateTime? @map("ai_extracted_at")
  aiExtractionMeta Json?     @map("ai_extraction_meta")

  createdByUser User? @relation("TankCreatedBy", fields: [createdBy], references: [id])

  shellCourses       TankShellCourse[]
  projects           TankProject[]
  findings           Finding[]
  dailyReports       DailyReport[]
  attachments        TankAttachment[]
  inspectionRequests InspectionRequest[]

  @@index([assetStatus])
  @@index([deletedAt])
  @@map("tanks")
}

model TankProject {
  id        String                @id @default(cuid())
  projectNo String                @unique @map("project_no")
  tankId    String                @map("tank_id")
  type      TankProjectTypeEnum   @default(OVERHAUL)
  status    TankProjectStatusEnum @default(PLANNED)

  contractorCompanyId String? @map("contractor_company_id")
  inspectionCompanyId String? @map("inspection_company_id")

  startDate           DateTime? @map("start_date") @db.Date
  estimatedFinishDate DateTime? @map("estimated_finish_date") @db.Date
  actualFinishDate    DateTime? @map("actual_finish_date") @db.Date

  description String?
  remarks     String?

  aiExtractedAt    DateTime? @map("ai_extracted_at")
  aiExtractionMeta Json?     @map("ai_extraction_meta")

  createdBy String?   @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tank              Tank     @relation(fields: [tankId], references: [id], onDelete: Cascade)
  contractorCompany Company? @relation("TankProjectContractor", fields: [contractorCompanyId], references: [id], onDelete: SetNull)
  inspectionCompany Company? @relation("TankProjectInspectionCompany", fields: [inspectionCompanyId], references: [id], onDelete: SetNull)
  createdByUser     User?    @relation("TankProjectCreatedBy", fields: [createdBy], references: [id])

  processes          TankProcess[]
  findings           Finding[]
  inspectionRequests InspectionRequest[]
  dailyReports       DailyReport[]

  @@index([tankId])
  @@index([type])
  @@index([status])
  @@index([contractorCompanyId])
  @@index([inspectionCompanyId])
  @@index([deletedAt])
  @@map("tank_projects")
}

model TankShellCourse {
  id             String  @id @default(cuid())
  tankId         String  @map("tank_id")
  courseNo       Int     @map("course_no")
  thicknessMm    Float?  @map("thickness_mm")
  plateDimension String? @map("plate_dimension")
  remarks        String?

  tank Tank @relation(fields: [tankId], references: [id], onDelete: Cascade)

  @@unique([tankId, courseNo])
  @@index([tankId])
  @@map("tank_shell_courses")
}

model TankAttachment {
  id            String @id @default(cuid())
  tankId        String @map("tank_id")
  fileStorageId String @map("file_storage_id")

  attachmentUrl String  @map("attachment_url")
  caption       String?
  sortOrder     Int     @default(0) @map("sort_order")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tank        Tank        @relation(fields: [tankId], references: [id], onDelete: Cascade)
  fileStorage FileStorage @relation(fields: [fileStorageId], references: [id], onDelete: Restrict)

  @@unique([tankId, fileStorageId])
  @@index([tankId])
  @@index([fileStorageId])
  @@index([deletedAt])
  @@map("tank_attachments")
}

model TankProcess {
  id                String            @id @default(cuid())
  projectId         String            @map("project_id")
  processTemplateId String            @map("process_template_id")
  name              String
  type              ProcessType
  sequenceOrder     Int               @map("sequence_order")
  status            ProcessStatusEnum @default(NOT_STARTED)
  startDate         DateTime?         @map("start_date")
  finishDate        DateTime?         @map("finish_date")
  remarks           String?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  project         TankProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  processTemplate ProcessTemplate @relation(fields: [processTemplateId], references: [id], onDelete: Restrict)

  checklistResults   ChecklistResult[]
  findings           Finding[]
  inspectionRequests InspectionRequest[]
  testRecords        TestRecord[]
  dailyReports       DailyReport[]

  @@unique([projectId, processTemplateId])
  @@index([projectId])
  @@index([status])
  @@map("tank_processes")
}

model ChecklistResult {
  id                   String              @id @default(cuid())
  tankProcessId        String              @map("tank_process_id")
  criteriaId           String?             @map("criteria_id")
  source               ChecklistSourceEnum @default(TEMPLATE) @map("source")
  status               ChecklistStatusEnum @default(NOT_CHECKED)
  // custom checklist fields (used when source = CUSTOM)
  customName           String?             @map("custom_name")
  customDescription    String?             @map("custom_description")
  customAcceptanceText String?             @map("custom_acceptance_text")
  customMethod         String?             @map("custom_method")
  customReferenceText  String?             @map("custom_reference_text")
  sequenceOrder        Int                 @default(0) @map("sequence_order")
  isRequired           Boolean             @default(true) @map("is_required")
  remarks              String?
  checkedBy            String?             @map("checked_by")
  checkedAt            DateTime?           @map("checked_at")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  tankProcess   TankProcess         @relation(fields: [tankProcessId], references: [id], onDelete: Cascade)
  criteria      AcceptanceCriteria? @relation(fields: [criteriaId], references: [id], onDelete: SetNull)
  checkedByUser User?               @relation("ChecklistCheckedBy", fields: [checkedBy], references: [id])

  // criteriaId is nullable for CUSTOM; NULL values are distinct in PostgreSQL UNIQUE so multiple custom items per process are allowed
  @@unique([tankProcessId, criteriaId])
  @@index([tankProcessId])
  @@index([criteriaId])
  @@index([status])
  @@index([source])
  @@map("checklist_results")
}

model Finding {
  id             String            @id @default(cuid())
  tankId         String            @map("tank_id")
  projectId      String?           @map("project_id")
  tankProcessId  String?           @map("tank_process_id")
  criteriaId     String?           @map("criteria_id")
  findingNo      String            @unique @map("finding_no")
  title          String
  description    String?
  
  locationDetail String?           @map("location_detail")
  status         FindingStatusEnum @default(OPEN)
  severity       SeverityEnum      @default(MAJOR)
  isBlocking     Boolean           @default(true) @map("is_blocking")
  createdBy      String?           @map("created_by")
  closedBy       String?           @map("closed_by")
  closedAt       DateTime?         @map("closed_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  deletedAt      DateTime?         @map("deleted_at")

  tank          Tank                @relation(fields: [tankId], references: [id], onDelete: Cascade)
  project       TankProject?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tankProcess   TankProcess?        @relation(fields: [tankProcessId], references: [id], onDelete: SetNull)
  criteria      AcceptanceCriteria? @relation(fields: [criteriaId], references: [id], onDelete: SetNull)
  createdByUser User?               @relation("FindingCreatedBy", fields: [createdBy], references: [id])
  closedByUser  User?               @relation("FindingClosedBy", fields: [closedBy], references: [id])

  @@index([tankId])
  @@index([projectId])
  @@index([tankProcessId])
  @@index([status])
  @@index([deletedAt])
  @@map("findings")
}

model InspectionRequest {
  id                 String                      @id @default(cuid())
  requestNo          String                      @unique @map("request_no")
  tankId             String?                     @map("tank_id")
  projectId          String?                     @map("project_id")
  tankProcessId      String?                     @map("tank_process_id")
  testType           InspectionRequestTypeEnum   @map("test_type")
  status             InspectionRequestStatusEnum @default(NOT_STARTED)
  requestDate        DateTime                    @map("request_date") @db.Date
  requestedBy        String?                     @map("requested_by")
  assetHolder        String?                     @map("asset_holder")
  executionParty     String?                     @map("execution_party")
  executionCompanyId String?                     @map("execution_company_id")
  receivedById       String?                     @map("received_by")
  preparedById       String?                     @map("prepared_by")
  approvedById       String?                     @map("approved_by")
  standardAndCode    String?                     @map("standard_and_code")
  requestLocation    String?                     @map("request_location")
  description        String?
  remarks            String?
  confirmedAt        DateTime?                   @map("confirmed_at")
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @updatedAt @map("updated_at")
  deletedAt          DateTime?                   @map("deleted_at")

  tank             Tank?        @relation(fields: [tankId], references: [id], onDelete: SetNull)
  project          TankProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tankProcess      TankProcess? @relation(fields: [tankProcessId], references: [id], onDelete: SetNull)
  requestedByUser  User?        @relation("InspectionRequestRequestedBy", fields: [requestedBy], references: [id])
  executionCompany Company?     @relation("InspectionRequestExecutionCompany", fields: [executionCompanyId], references: [id], onDelete: SetNull)
  receivedByUser   User?        @relation("InspectionRequestReceivedBy", fields: [receivedById], references: [id])
  preparedByUser   User?        @relation("InspectionRequestPreparedBy", fields: [preparedById], references: [id])
  approvedByUser   User?        @relation("InspectionRequestApprovedBy", fields: [approvedById], references: [id])

  items       InspectionRequestItem[]
  attachments InspectionRequestAttachment[]
  testRecords TestRecord[]

  @@index([tankId])
  @@index([projectId])
  @@index([tankProcessId])
  @@index([status])
  @@index([testType])
  @@index([executionCompanyId])
  @@index([deletedAt])
  @@map("inspection_requests")
}

model InspectionRequestItem {
  id                  String                   @id @default(cuid())
  inspectionRequestId String                   @map("inspection_request_id")
  objectType          InspectionObjectTypeEnum @map("object_type")
  objectName          String?                  @map("object_name")
  quantity            Int                      @default(1)
  unit                String?
  locationDetail      String?                  @map("location_detail")
  remarks             String?
  sortOrder           Int                      @default(0) @map("sort_order")
  metadata            Json?
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")

  inspectionRequest InspectionRequest @relation(fields: [inspectionRequestId], references: [id], onDelete: Cascade)
  testRecords       TestRecord[]

  @@index([inspectionRequestId])
  @@map("inspection_request_items")
}

model InspectionRequestAttachment {
  id                  String                              @id @default(cuid())
  inspectionRequestId String                              @map("inspection_request_id")
  fileStorageId       String                              @map("file_storage_id")
  attachmentUrl       String                              @map("attachment_url")
  attachmentType      InspectionRequestAttachmentTypeEnum @default(SUPPORTING_DOCUMENT) @map("attachment_type")
  caption             String?
  sortOrder           Int                                 @default(0) @map("sort_order")
  createdAt           DateTime                            @default(now()) @map("created_at")
  updatedAt           DateTime                            @updatedAt @map("updated_at")
  deletedAt           DateTime?                           @map("deleted_at")

  inspectionRequest InspectionRequest @relation(fields: [inspectionRequestId], references: [id], onDelete: Cascade)
  fileStorage       FileStorage       @relation(fields: [fileStorageId], references: [id], onDelete: Restrict)

  @@unique([inspectionRequestId, fileStorageId])
  @@index([inspectionRequestId])
  @@index([fileStorageId])
  @@index([attachmentType])
  @@index([deletedAt])
  @@map("inspection_request_attachments")
}

model TestRecord {
  id                      String               @id @default(cuid())
  inspectionRequestId     String               @map("inspection_request_id")
  inspectionRequestItemId String?              @map("inspection_request_item_id")
  tankProcessId           String?              @map("tank_process_id")
  testDate                DateTime?            @map("test_date") @db.Date
  testPressure            Float?               @map("test_pressure")
  pressureUnit            String?              @map("pressure_unit")
  holdingTime             String?              @map("holding_time")
  testMedium              String?              @map("test_medium")
  leakIndication          Boolean?             @map("leak_indication")
  status                  TestResultStatusEnum @default(NOT_STARTED)
  result                  ProcessResultEnum    @default(PENDING)
  remarks                 String?
  createdBy               String?              @map("created_by")
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")

  inspectionRequest     InspectionRequest      @relation(fields: [inspectionRequestId], references: [id], onDelete: Cascade)
  inspectionRequestItem InspectionRequestItem? @relation(fields: [inspectionRequestItemId], references: [id], onDelete: SetNull)
  tankProcess           TankProcess?           @relation(fields: [tankProcessId], references: [id], onDelete: SetNull)
  createdByUser         User?                  @relation("TestRecordCreatedBy", fields: [createdBy], references: [id])
  attachments           TestRecordAttachment[]

  @@index([inspectionRequestId])
  @@index([inspectionRequestItemId])
  @@index([tankProcessId])
  @@index([status])
  @@map("test_records")
}

model TestRecordAttachment {
  id            String    @id @default(cuid())
  testRecordId  String    @map("test_record_id")
  fileStorageId String    @map("file_storage_id")
  attachmentUrl String    @map("attachment_url")
  caption       String?
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  testRecord  TestRecord  @relation(fields: [testRecordId], references: [id], onDelete: Cascade)
  fileStorage FileStorage @relation(fields: [fileStorageId], references: [id], onDelete: Restrict)

  @@unique([testRecordId, fileStorageId])
  @@index([testRecordId])
  @@index([fileStorageId])
  @@index([deletedAt])
  @@map("test_record_attachments")
}

model DailyReport {
  id             String                @id @default(cuid())
  tankId         String?               @map("tank_id")
  projectId      String?               @map("project_id")
  tankProcessId  String?               @map("tank_process_id")
  reportDate     DateTime              @map("report_date") @db.Date
  activityType   DailyActivityTypeEnum @map("activity_type")
  title          String
  description    String
  recommendation String?
  inspectorId    String?               @map("inspector_id")
  pertaminaPicId String?               @map("pertamina_pic_id")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  deletedAt      DateTime?             @map("deleted_at")

  aiSuggestedDescription String?   @map("ai_suggested_description")
  aiAnalyzedAt           DateTime? @map("ai_analyzed_at")
  aiAnalysisMeta         Json?     @map("ai_analysis_meta")

  attachments DailyReportAttachment[]

  tank        Tank?        @relation(fields: [tankId], references: [id], onDelete: SetNull)
  project     TankProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tankProcess TankProcess? @relation(fields: [tankProcessId], references: [id], onDelete: SetNull)
  inspector   User?        @relation("DailyReportInspector", fields: [inspectorId], references: [id])

  @@index([tankId])
  @@index([projectId])
  @@index([tankProcessId])
  @@index([reportDate])
  @@map("daily_reports")
}

model DailyReportAttachment {
  id            String @id @default(cuid())
  dailyReportId String @map("daily_report_id")
  fileStorageId String @map("file_storage_id")

  attachmentUrl String  @map("attachment_url")
  caption       String?
  sortOrder     Int     @default(0) @map("sort_order")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  dailyReport DailyReport @relation(fields: [dailyReportId], references: [id], onDelete: Cascade)
  fileStorage FileStorage @relation(fields: [fileStorageId], references: [id], onDelete: Restrict)

  @@unique([dailyReportId, fileStorageId])
  @@index([dailyReportId])
  @@index([fileStorageId])
  @@index([deletedAt])
  @@map("daily_report_attachments")
}
