generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum RoleEnum {
  USER
  INSPECTOR
  ADMIN
  SUPER_ADMIN
}

enum StatusEnum {
  ACTIVE
  INACTIVE
  BANNED
}

enum VerificationType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum OAuthProvider {
  GOOGLE
  GITHUB
}

enum NotificationType {
  INSPECTION_ASSIGNED
  INSPECTION_REMINDER
  INSPECTION_REQUEST_SUBMITTED
  INSPECTION_REQUEST_REVIEWED
  FINDING_CREATED
  FINDING_STATUS_CHANGED
  TEST_COMPLETED
  DAILY_REPORT_CREATED
  TANK_CREATED
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationStatus {
  ENABLED
  DISABLED
}

enum CompanyType {
  OWNER
  INSPECTOR_COMPANY
  CONTRACTOR
}

// ─── Auth Models ─────────────────────────────────────────────────────────────

model User {
  id                   String     @id @default(cuid())
  email                String     @unique
  passwordHash         String?    @map("password_hash")
  name                 String
  avatar               String?
  status               StatusEnum @default(ACTIVE)
  role                 RoleEnum   @default(USER)
  verifiedAt           DateTime?  @map("verified_at")
  lastLogin            DateTime?  @map("last_login")
  lastChangePasswordAt DateTime?  @map("last_change_password_at")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  deletedAt            DateTime?  @map("deleted_at")

  twoFactorEnabled     Boolean  @default(false) @map("two_factor_enabled")
  twoFactorSecret      String?  @map("two_factor_secret")
  twoFactorBackupCodes String[] @map("two_factor_backup_codes")

  sessions             Session[]
  notifications        Notification[]
  notificationSettings NotificationSetting[]
  verifications        UserVerification[]
  activities           UserActivityLog[]
  oauthAccounts        OAuthAccount[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model UserVerification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  token     String           @unique
  usedAt    DateTime?        @map("used_at")
  createdAt DateTime         @default(now()) @map("created_at")
  expiresAt DateTime         @map("expires_at")
  type      VerificationType @map("type")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_verifications")
}

model UserActivityLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_activity_logs")
}

model OAuthAccount {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  provider          OAuthProvider
  providerAccountId String        @map("provider_account_id")
  accessToken       String?       @map("access_token")
  refreshToken      String?       @map("refresh_token")
  expiresAt         DateTime?     @map("expires_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

// ─── File Storage ─────────────────────────────────────────────────────────────

model FileStorage {
  id        String   @id @default(cuid())
  targetId  String?  @map("target_id")
  url       String
  module    String
  mimeType  String?  @map("mime_type")
  size      Int
  meta      Json?
  path      String
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")

  @@index([targetId, module])
  @@index([isUsed, createdAt])
  @@map("file_storages")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model NotificationSetting {
  id        String              @id @default(cuid())
  userId    String              @map("user_id")
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(ENABLED)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
  @@index([userId])
  @@map("notification_settings")
}

model Notification {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  title       String
  description String?
  type        NotificationType
  metadata    Json?
  readAt      DateTime?        @map("read_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  deletedAt   DateTime?        @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@index([userId, readAt])
  @@map("notifications")
}

enum MasterDataStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum DocumentType {
  STANDARD
  PROCEDURE
  SPECIFICATION
  WPS
  ITP
  PROJECT_PROCEDURE
}

enum AcceptanceType {
  PASS_FAIL
  NUMERIC_MIN
  NUMERIC_MAX
  NUMERIC_RANGE
  TEXT
  DEPENDENCY
}

enum CriteriaSeverity {
  CRITICAL
  MAJOR
  MINOR
  OBSERVATION
}

enum ProcessType {
  WORK
  INSPECTION
  TEST
  NDT
  COATING
  COMMISSIONING
}

enum ProcessResultEnum {
  PASSED
  FAILED
  PENDING
  NOT_APPLICABLE
}

// ─── Company ──────────────────────────────────────────────────────────────────

model Company {
  id        String      @id @default(cuid())
  name      String
  type      CompanyType
  address   String?
  phone     String?
  email     String?
  logoUrl   String?     @map("logo_url")
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  deletedAt DateTime?   @map("deleted_at")

  @@index([type])
  @@index([isActive])
  @@index([deletedAt])
  @@map("companies")
}

// ─── Master Data ──────────────────────────────────────────────────────────────

model ReferenceDocument {
  id           String           @id @default(cuid())
  code         String           @unique
  title        String
  documentType DocumentType     @map("document_type")
  revision     String?
  issuer       String?
  fileUrl      String?          @map("file_url")
  status       MasterDataStatus @default(DRAFT)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  deletedAt    DateTime?        @map("deleted_at")

  criteriaRefs CriteriaReference[]

  @@index([code])
  @@index([documentType])
  @@index([status])
  @@index([deletedAt])
  @@map("reference_documents")
}

model AcceptanceCriteria {
  id             String           @id @default(cuid())
  code           String           @unique
  name           String
  description    String?
  acceptanceType AcceptanceType   @map("acceptance_type")
  operator       String?
  minValue       Float?           @map("min_value")
  maxValue       Float?           @map("max_value")
  unit           String?
  acceptanceText String?          @map("acceptance_text")
  method         String?
  tools          String?
  isRequired     Boolean          @default(true) @map("is_required")
  severity       CriteriaSeverity @default(MAJOR)
  status         MasterDataStatus @default(DRAFT)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  criteriaRefs    CriteriaReference[]
  processCriteria ProcessCriteriaTemplate[]

  @@index([code])
  @@index([acceptanceType])
  @@index([status])
  @@index([deletedAt])
  @@map("acceptance_criteria")
}

model CriteriaReference {
  id                  String             @id @default(cuid())
  criteriaId          String             @map("criteria_id")
  referenceDocumentId String             @map("reference_document_id")
  clause              String?
  page                String?
  notes               String?
  createdAt           DateTime           @default(now()) @map("created_at")

  criteria          AcceptanceCriteria @relation(fields: [criteriaId], references: [id], onDelete: Cascade)
  referenceDocument ReferenceDocument  @relation(fields: [referenceDocumentId], references: [id], onDelete: Restrict)

  @@unique([criteriaId, referenceDocumentId])
  @@index([criteriaId])
  @@index([referenceDocumentId])
  @@map("criteria_references")
}

model ProcessTemplate {
  id                String      @id @default(cuid())
  code              String      @unique
  name              String
  type              ProcessType
  sequenceOrder     Int         @map("sequence_order")
  isOptional        Boolean     @default(false) @map("is_optional")
  applicabilityRule String?     @map("applicability_rule")
  isActive          Boolean     @default(true) @map("is_active")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  deletedAt         DateTime?   @map("deleted_at")

  processCriteria ProcessCriteriaTemplate[]
  dependants      ProcessDependency[]       @relation("DependantProcess")
  dependencies    ProcessDependency[]       @relation("RequiredProcess")

  @@index([type])
  @@index([sequenceOrder])
  @@index([isActive])
  @@index([deletedAt])
  @@map("process_templates")
}

model ProcessCriteriaTemplate {
  id                String    @id @default(cuid())
  processTemplateId String    @map("process_template_id")
  criteriaId        String    @map("criteria_id")
  sequenceOrder     Int       @default(0) @map("sequence_order")
  isRequired        Boolean   @default(true) @map("is_required")
  applicabilityRule String?   @map("applicability_rule")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  processTemplate ProcessTemplate    @relation(fields: [processTemplateId], references: [id], onDelete: Cascade)
  criteria        AcceptanceCriteria @relation(fields: [criteriaId], references: [id], onDelete: Restrict)

  @@unique([processTemplateId, criteriaId])
  @@index([processTemplateId])
  @@index([criteriaId])
  @@map("process_criteria_templates")
}

model ProcessDependency {
  id                        String            @id @default(cuid())
  processTemplateId         String            @map("process_template_id")
  requiredProcessTemplateId String            @map("required_process_template_id")
  requiredResult            ProcessResultEnum @default(PASSED) @map("required_result")
  isRequired                Boolean           @default(true) @map("is_required")
  applicabilityRule         String?           @map("applicability_rule")
  createdAt                 DateTime          @default(now()) @map("created_at")
  updatedAt                 DateTime          @updatedAt @map("updated_at")

  processTemplate         ProcessTemplate @relation("DependantProcess", fields: [processTemplateId], references: [id], onDelete: Cascade)
  requiredProcessTemplate ProcessTemplate @relation("RequiredProcess", fields: [requiredProcessTemplateId], references: [id], onDelete: Restrict)

  @@unique([processTemplateId, requiredProcessTemplateId])
  @@index([processTemplateId])
  @@index([requiredProcessTemplateId])
  @@map("process_dependencies")
}
